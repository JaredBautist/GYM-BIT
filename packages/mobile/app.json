{
  "expo": {
    "name": "GymBit",
    "slug": "gymbit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.gymbit.mobile",
      "infoPlist": {
        "NSHealthShareUsageDescription": "GymBit reads your health data to track fitness progress.",
        "NSHealthUpdateUsageDescription": "GymBit writes workout data to Apple Health.",
        "NSCameraUsageDescription": "GymBit uses the camera to scan barcodes and photograph food.",
        "NSPhotoLibraryUsageDescription": "GymBit accesses photos to identify food items."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "app.gymbit.mobile",
      "permissions": [
        "CAMERA",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GymBit to access your camera."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sqlite"
    ],
    "scheme": "gymbit"
  }
}
