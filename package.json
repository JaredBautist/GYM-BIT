{
  "name": "gymbit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/mobile",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start": "npm run start --workspace @gymbit/mobile -- --clear",
    "mobile": "npm run start --workspace @gymbit/mobile -- --clear",
    "mobile:web": "npm run start --workspace @gymbit/mobile -- --web --clear",
    "mobile:android": "npm run android --workspace @gymbit/mobile",
    "start:lan": "npm run start --workspace @gymbit/mobile -- --lan --clear",
    "start:tunnel": "npm run start --workspace @gymbit/mobile -- --tunnel --clear",
    "mobile:lan": "npm run start --workspace @gymbit/mobile -- --lan --clear",
    "mobile:tunnel": "npm run start --workspace @gymbit/mobile -- --tunnel --clear",
    "postinstall": "node scripts/patch-react-native-domexception.js",
    "dev:android": "npm run android --workspace @gymbit/mobile",
    "dev:start": "npm run start --workspace @gymbit/mobile -- --dev-client --clear",
    "prebuild:mobile": "npx expo prebuild --platform android --clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "ajv": "^8.20.0",
    "babel-preset-expo": "^56.0.13",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.10",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "main": "expo-router/entry",
  "dependencies": {
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-worklets": "0.5.1"
  }
}
